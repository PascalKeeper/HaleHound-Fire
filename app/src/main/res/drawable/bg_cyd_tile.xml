<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/cyd_green_ghost" />
            <stroke android:width="1dp" android:color="@color/cyd_green" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/cyd_panel" />
            <stroke android:width="1dp" android:color="@color/cyd_border_hi" />
            <corners android:radius="2dp" />
        </shape>
    </item>
</selector>
