<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.HaleHoundFire" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/hh_accent</item>
        <item name="colorPrimaryVariant">@color/hh_accent_dim</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/hh_info</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/hh_bg</item>
        <item name="colorSurface">@color/hh_surface</item>
        <item name="colorOnSurface">@color/hh_text</item>
        <item name="android:statusBarColor">@color/hh_bg</item>
        <item name="android:navigationBarColor">@color/hh_bg</item>
        <item name="android:windowBackground">@color/hh_bg</item>
        <item name="android:textColorPrimary">@color/hh_text</item>
        <item name="android:textColorSecondary">@color/hh_muted</item>
        <item name="materialButtonStyle">@style/Widget.HaleHound.Button</item>
    </style>

    <style name="Widget.HaleHound.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/hh_accent</item>
        <item name="android:textColor">@color/black</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.HaleHound.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/hh_border</item>
        <item name="android:textColor">@color/hh_text</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
