<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cyd_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="CYD LINK › TELEMETRY + LOOT"
            android:textColor="@color/cyd_amber"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="monospace"
            android:text="Brain plane: live probe · pull loot off SD · no laptop required"
            android:textColor="@color/cyd_text_muted"
            android:textSize="10sp" />

        <EditText
            android:id="@+id/hostInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_cyd_input"
            android:fontFamily="monospace"
            android:hint="http://192.168.4.1"
            android:inputType="textUri"
            android:padding="10dp"
            android:textColor="@color/cyd_text"
            android:textColorHint="@color/cyd_text_muted"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDiscover"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="3dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="PROBE"
                android:textSize="11sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRefresh"
                style="@style/Widget.HaleHound.Button.Outline"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="3dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="REFRESH"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/telemetryBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_cyd_panel"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp"
            android:minHeight="100dp"
            android:padding="10dp"
            android:text="Telemetry: not probed yet.\nJoin CYD softAP then PROBE."
            android:textColor="@color/cyd_text"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/pathsBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_cyd_panel"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp"
            android:padding="10dp"
            android:text="HTTP paths: —"
            android:textColor="@color/cyd_text_dim"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/lootBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_cyd_panel"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp"
            android:minHeight="80dp"
            android:padding="10dp"
            android:text="Loot hints: —"
            android:textColor="@color/cyd_text_dim"
            android:textSize="10sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPullLoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="PULL LOOT → FIRE VAULT" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenHost"
            style="@style/Widget.HaleHound.Button.Outline"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="OPEN IN SILK"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/vaultBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_cyd_panel"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp"
            android:padding="10dp"
            android:text="Local vault: empty"
            android:textColor="@color/cyd_text_dim"
            android:textSize="10sp" />
    </LinearLayout>
</ScrollView>
