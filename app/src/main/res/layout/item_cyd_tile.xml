<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tileRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="3dp"
    android:background="@drawable/bg_cyd_tile"
    android:gravity="center"
    android:minHeight="72dp"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:id="@+id/tileIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:text="◈"
        android:textColor="@color/cyd_green"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tileTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:letterSpacing="0.04"
        android:text="WIFI"
        android:textAllCaps="true"
        android:textColor="@color/cyd_text"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tileSub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:gravity="center"
        android:text="scan"
        android:textColor="@color/cyd_text_muted"
        android:textSize="9sp" />
</LinearLayout>
