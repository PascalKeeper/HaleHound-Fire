<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cydHeader"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_cyd_header"
    android:orientation="vertical"
    android:paddingStart="10dp"
    android:paddingTop="8dp"
    android:paddingEnd="10dp"
    android:paddingBottom="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/headerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:letterSpacing="0.08"
            android:text="HALEHOUND-FIRE"
            android:textAllCaps="true"
            android:textColor="@color/cyd_amber"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/headerVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="v0.3"
            android:textColor="@color/cyd_text_muted"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/modeBanner"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_cyd_banner_blue"
            android:fontFamily="monospace"
            android:gravity="center"
            android:letterSpacing="0.1"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="◆ BLUE TEAM MODE"
            android:textAllCaps="true"
            android:textColor="@color/cyd_cyan"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/headerChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_cyd_banner_amber"
            android:fontFamily="monospace"
            android:paddingStart="8dp"
            android:paddingTop="4dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp"
            android:text="FIRE OS"
            android:textColor="@color/cyd_amber"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="6dp"
        android:background="@color/cyd_green_dim" />
</LinearLayout>
