<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cyd_bg"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:text="SENSOR HUNT › FLOCK · TAGS · CAMS"
        android:textColor="@color/cyd_amber"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:text="Passive BLE + Wi‑Fi + LAN · Blue Team · authorized nets only"
        android:textColor="@color/cyd_text_muted"
        android:textSize="9sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHunt"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginEnd="3dp"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="HUNT"
            android:textSize="11sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHuntNoLan"
            style="@style/Widget.HaleHound.Button.Outline"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="3dp"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="RF ONLY"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/huntSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_cyd_panel"
        android:fontFamily="monospace"
        android:padding="10dp"
        android:text="Tap HUNT — scans BLE (~8s), Wi‑Fi, optional LAN cam ports."
        android:textColor="@color/cyd_text"
        android:textSize="10sp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_weight="1"
        android:background="@drawable/bg_cyd_panel"
        android:padding="8dp">

        <TextView
            android:id="@+id/huntResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp"
            android:textColor="@color/cyd_text_dim"
            android:textIsSelectable="true"
            android:textSize="10sp"
            android:text="(no hunt yet)" />
    </ScrollView>
</LinearLayout>
